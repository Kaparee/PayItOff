<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="MainBackground">#121826</Color>
    <Color x:Key="BgDark">#121826</Color>
    <Color x:Key="SurfaceDark">#1F2937</Color>
    <Color x:Key="SurfaceLight">#2A3648</Color>
    <Color x:Key="Border">#374151</Color>
    <Color x:Key="BorderGray">#374151</Color>
    <Color x:Key="BrandViolet">#8B5CF6</Color>
    <Color x:Key="PrimaryViolet">#8B5CF6</Color>
    <Color x:Key="TextMain">#F3F4F6</Color>
    <Color x:Key="TextSubtle">#9CA3AF</Color>

    <Color x:Key="StatusGreen">#10B981</Color>
    <Color x:Key="StatusRed">#EF4444</Color>
    <Color x:Key="StatusAmber">#F59E0B</Color>

    <Color x:Key="Primary">#8B5CF6</Color>
    <Color x:Key="Secondary">#1F2937</Color>
    <Color x:Key="Tertiary">#374151</Color>
    <Color x:Key="White">#F3F4F6</Color>
    <Color x:Key="Black">#121826</Color>
    <Color x:Key="Gray950">#121826</Color>
    <Color x:Key="Gray900">#1F2937</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource BrandViolet}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceDark}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource MainBackground}"/>

</ResourceDictionary>