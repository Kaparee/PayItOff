<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PayItOff.MauiClient.Views.LoginPage"
             Title="Zaloguj się">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Label Text="PayItOff" FontSize="32" HorizontalOptions="Center" FontAttributes="Bold" />

        <Entry Placeholder="Email lub Nickname" 
               Text="{Binding EmailOrNickname}" />

        <Entry Placeholder="Hasło" 
               IsPassword="True"
               Text="{Binding Password}" />

        <Button Text="Zaloguj" 
                Command="{Binding LoginCommand}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>